# macOS
.DS_Store

# Editor
.vscode/
.idea/
*.swp
*.swo
*~

# IDE / AI-extension artifacts — local only, not shippable framework content
.specstory/
.cursorindexingignore

# Build / temp
__pycache__/
*.py[cod]
*.egg-info/
build/
dist/
node_modules/
.venv/
venv/

# Logs
*.log

# Orchestrator state (per adopter; gitignored if running orchestrator)
.orchestrator/
eval/runs/

# Loop run artifacts — default run dir <repo>/.runs/<loop_id> (state/audit/
# transcripts/checkpoints). In-repo for discoverability, gitignored so a loop's own
# writes never enter the delivered diff. --run-dir / --campaign-run-dir override.
.runs/

# Local override files
*.local
*.local.*

# Local secrets / env — NEVER commit. `.env.example` (committed) ships NAMES only;
# real provider keys go in `.env.local`, which run_loop.py loads on --allow-real.
.env
.env.local
.env.*.local

# Codex design/impl gate artifacts (prompts + verdicts + large JSON output)
.gate/
