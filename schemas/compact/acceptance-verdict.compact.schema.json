{
  "$schema": "https://json-schema.org/draft/2020-12/schema",
  "$id": "https://aidazi.framework/schemas/compact/acceptance-verdict.compact.schema.json",
  "type": "object",
  "required": [
    "milestone_verdict",
    "cases",
    "suggested_route"
  ],
  "additionalProperties": false,
  "properties": {
    "milestone_verdict": {
      "type": "string",
      "enum": [
        "pass",
        "fix_required",
        "needs_human"
      ]
    },
    "acceptance_class": {
      "type": "string",
      "enum": [
        "static",
        "browser_e2e"
      ]
    },
    "authoritative": {
      "type": "boolean"
    },
    "calibration_record_id": {
      "type": "string"
    },
    "closure_contract_ref": {
      "type": "string"
    },
    "functional_checklist_ref": {
      "type": "string"
    },
    "calibration_status": {
      "type": "string",
      "enum": [
        "calibrated",
        "uncalibrated",
        "not_required"
      ]
    },
    "cases": {
      "type": "array",
      "minItems": 1,
      "items": {
        "type": "object",
        "required": [
          "case_id",
          "criterion",
          "verdict",
          "rationale"
        ],
        "additionalProperties": false,
        "properties": {
          "case_id": {
            "type": "string"
          },
          "criterion_id": {
            "type": "string",
            "minLength": 1
          },
          "criterion": {
            "type": "string"
          },
          "evidence_path": {
            "type": "string"
          },
          "functional_evidence_refs": {
            "type": "array",
            "items": {
              "type": "object"
            }
          },
          "verdict": {
            "type": "string",
            "enum": [
              "pass",
              "fail",
              "partial"
            ]
          },
          "rationale": {
            "type": "string",
            "minLength": 1
          }
        }
      }
    },
    "failure_briefs": {
      "type": "array",
      "items": {
        "type": "object",
        "required": [
          "title",
          "contract_clause_violated",
          "proposed_scope",
          "severity"
        ],
        "additionalProperties": false,
        "properties": {
          "title": {
            "type": "string",
            "minLength": 1
          },
          "contract_clause_violated": {
            "type": "string"
          },
          "proposed_scope": {
            "type": "string"
          },
          "severity": {
            "type": "string",
            "enum": [
              "P0",
              "P1",
              "P2"
            ]
          }
        }
      }
    },
    "residual_risks": {
      "type": "array",
      "items": {
        "type": "string"
      }
    },
    "suggested_route": {
      "type": "string",
      "enum": [
        "deliver_fix_iteration",
        "re_acceptance_after_evidence",
        "research_contract_revision",
        "n/a"
      ]
    },
    "human_confirm_checkpoint_path": {
      "type": "string"
    }
  },
  "allOf": [
    {
      "if": {
        "required": [
          "acceptance_class"
        ],
        "properties": {
          "acceptance_class": {
            "const": "browser_e2e"
          }
        }
      },
      "then": {
        "properties": {
          "cases": {
            "items": {
              "required": [
                "criterion_id",
                "functional_evidence_refs"
              ],
              "properties": {
                "functional_evidence_refs": {
                  "type": "array",
                  "minItems": 1,
                  "items": {
                    "type": "object",
                    "additionalProperties": false,
                    "required": [
                      "kind",
                      "path",
                      "sha256"
                    ],
                    "properties": {
                      "kind": {
                        "type": "string",
                        "enum": [
                          "screenshot",
                          "console",
                          "network",
                          "manifest",
                          "checklist",
                          "backend_state"
                        ]
                      },
                      "path": {
                        "type": "string",
                        "pattern": "^\\.orchestrator/audit/browser/.+"
                      },
                      "sha256": {
                        "type": "string",
                        "pattern": "^[0-9a-f]{64}$"
                      }
                    }
                  }
                }
              }
            }
          }
        }
      },
      "else": {
        "properties": {
          "cases": {
            "items": {
              "required": [
                "evidence_path"
              ],
              "properties": {
                "evidence_path": {
                  "pattern": "^eval/runs/.+"
                }
              }
            }
          }
        }
      }
    },
    {
      "if": {
        "properties": {
          "milestone_verdict": {
            "const": "fix_required"
          }
        }
      },
      "then": {
        "required": [
          "failure_briefs"
        ],
        "properties": {
          "failure_briefs": {
            "minItems": 1
          }
        }
      }
    }
  ],
  "x-canonical-source": "acceptance-verdict.schema.json",
  "x-canonical-sha256": "60590e269dc10199167cbd56996d89901aff9305750b1573ffc9781ef87117a2"
}
