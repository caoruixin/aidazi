{
  "$schema": "https://json-schema.org/draft/2020-12/schema",
  "$id": "https://aidazi.framework/schemas/research-brief.schema.json",
  "type": "object",
  "required": [
    "brief_id",
    "input_path",
    "customer_signed",
    "closure_contract",
    "scope_in",
    "scope_out",
    "anti_goal",
    "kpi"
  ],
  "additionalProperties": false,
  "properties": {
    "brief_id": {
      "type": "string",
      "minLength": 1
    },
    "input_path": {
      "type": "string",
      "enum": ["path_1_customer_ask", "path_2_bad_case_matured"]
    },
    "related_proposals": {
      "type": "array",
      "items": {"type": "string"}
    },
    "related_failure_briefs": {
      "type": "array",
      "items": {"type": "string"}
    },
    "related_r_items": {
      "type": "array",
      "items": {"type": "string"}
    },
    "customer_signed": {
      "type": "boolean"
    },
    "sign_off_date": {
      "type": ["string", "null"],
      "format": "date"
    },
    "closure_contract": {
      "type": "object",
      "required": ["positive_shape", "anti_pattern", "anchor_phrases"],
      "additionalProperties": false,
      "properties": {
        "positive_shape": {
          "type": "string",
          "minLength": 1
        },
        "anti_pattern": {
          "type": "string",
          "minLength": 1
        },
        "anchor_phrases": {
          "type": "array",
          "items": {"type": "string", "minLength": 1},
          "minItems": 1
        }
      }
    },
    "scope_in": {
      "type": "array",
      "items": {"type": "string"},
      "minItems": 1
    },
    "scope_out": {
      "type": "array",
      "items": {"type": "string"},
      "minItems": 1
    },
    "anti_goal": {
      "type": "string",
      "minLength": 1
    },
    "kpi": {
      "type": "array",
      "items": {
        "type": "object",
        "required": ["name", "target"],
        "additionalProperties": false,
        "properties": {
          "name": {"type": "string", "minLength": 1},
          "target": {"type": "string", "minLength": 1},
          "measurement": {"type": "string"}
        }
      },
      "minItems": 1
    },
    "risk_and_impact": {
      "type": "string"
    }
  }
}
