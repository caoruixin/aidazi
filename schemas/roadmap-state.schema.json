{
  "$schema": "https://json-schema.org/draft/2020-12/schema",
  "$id": "https://aidazi.framework/schemas/roadmap-state.schema.json",
  "title": "Control-plane roadmap state",
  "description": "Machine-owned roadmap index for the Control Plane. It is the source used to generate docs/milestone-backlog.md for human reading. In single_milestone mode, charter.yaml remains the active execution source and campaign-plan.json is optional/inactive. In campaign mode, campaign-plan.json is the executable multi-milestone queue and must match this state/projection.",
  "type": "object",
  "required": [
    "schema_version",
    "updated_at",
    "delivery_mode",
    "roadmap_title",
    "source_refs",
    "milestones"
  ],
  "additionalProperties": false,
  "properties": {
    "schema_version": {
      "type": "string",
      "const": "roadmap-state.v1"
    },
    "updated_at": {
      "type": "string",
      "format": "date-time"
    },
    "delivery_mode": {
      "type": "string",
      "enum": ["single_milestone", "campaign"],
      "description": "single_milestone is the default human-facing topology: charter.yaml is the active executable source. campaign is opt-in: campaign-plan.json is the executable multi-milestone queue."
    },
    "autonomy_level": {
      "type": ["string", "null"],
      "enum": ["human_in_the_loop", "human_on_the_loop", "fully_autonomous_within_budget", null],
      "description": "Optional mirror of charter.autonomy.level. It informs the recommended delivery_mode but does not replace it."
    },
    "roadmap_title": {
      "type": "string",
      "minLength": 1
    },
    "campaign_id": {
      "type": ["string", "null"],
      "pattern": "^[A-Za-z0-9][A-Za-z0-9._-]{0,127}$"
    },
    "source_refs": {
      "type": "object",
      "additionalProperties": false,
      "required": ["generated_backlog"],
      "properties": {
        "generated_backlog": { "type": "string", "minLength": 1 },
        "charter": { "type": ["string", "null"] },
        "campaign_plan": { "type": ["string", "null"] },
        "active_research_brief": { "type": ["string", "null"] },
        "active_milestone_objective": { "type": ["string", "null"] }
      }
    },
    "active": {
      "type": "object",
      "additionalProperties": false,
      "properties": {
        "milestone_id": { "type": ["string", "null"] },
        "subsprint_id": { "type": ["string", "null"] },
        "phase": { "type": ["string", "null"] }
      }
    },
    "milestones": {
      "type": "array",
      "minItems": 1,
      "items": {
        "type": "object",
        "required": ["id", "title", "objective", "depends_on", "status"],
        "additionalProperties": false,
        "properties": {
          "id": {
            "type": "string",
            "minLength": 1,
            "pattern": "^[A-Za-z0-9][A-Za-z0-9._-]{0,127}$"
          },
          "title": { "type": "string", "minLength": 1 },
          "objective": { "type": "string", "minLength": 1 },
          "depends_on": {
            "type": "array",
            "items": { "type": "string", "minLength": 1 },
            "uniqueItems": true
          },
          "status": {
            "type": "string",
            "enum": [
              "planned",
              "needs_research_gate1",
              "signed_gate1",
              "active",
              "closed",
              "deferred"
            ]
          },
          "research_brief": { "type": ["string", "null"] },
          "signed_at": { "type": ["string", "null"] },
          "subsprint_sequence": {
            "type": "array",
            "items": { "type": "string", "pattern": "^[A-Za-z0-9][A-Za-z0-9._-]{0,127}$" },
            "uniqueItems": true
          },
          "notes": { "type": ["string", "null"] }
        }
      }
    }
  }
}
